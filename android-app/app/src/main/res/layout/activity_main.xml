<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="4dp">

        <EditText
            android:id="@+id/urlInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/hint_call_link"
            android:inputType="textUri"
            android:singleLine="true"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/clearButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_clear"
            android:padding="6dp"
            android:scaleType="fitXY"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#888888" />

        <Button
            android:id="@+id/goButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="64dp"
            android:text="@string/btn_go" />

        <ImageButton
            android:id="@+id/gearButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_settings"
            android:padding="6dp"
            android:scaleType="fitXY"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="#888888" />
    </LinearLayout>

    <TextView
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/status_idle"
        android:gravity="center"
        android:paddingVertical="4dp"
        android:text="@string/status_idle"
        android:textColor="@color/white"
        android:textSize="12sp" />

    <FrameLayout
        android:id="@+id/logContainer"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/logView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#111111"
            android:fontFamily="monospace"
            android:padding="4dp"
            android:scrollbars="vertical"
            android:textColor="#00FF00"
            android:textSize="11sp" />

        <ImageButton
            android:id="@+id/shareLogsButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_margin="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/share_logs"
            android:padding="4dp"
            android:scaleType="fitXY"
            android:src="@android:drawable/ic_menu_share"
            app:tint="#888888" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/webViewContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/toggleWebViewButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingVertical="6dp">

            <ImageView
                android:id="@+id/toggleWebViewArrow"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_down"
                app:tint="?android:attr/textColorPrimary" />

            <TextView
                android:id="@+id/toggleWebViewLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/expand_webview"
                android:textSize="13sp" />

        </LinearLayout>

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
